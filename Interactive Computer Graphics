let isDragging = false; 
let previousX = 0;
let previousY = 0;
let r = 0, g = 0, b = 0, a = 255; // สี
let degree = 0; //มุม
let scale = 1;
let mouseX = 0, mouseY = 0; // Mouse position เมาส์

canvas.addEventListener('click', (event) => {

});

canvas.addEventListener('mousedown', (event) => {
  isDragging = true;
  console.log('Mouse down', event.offsetX, event.offsetY);
});

canvas.addEventListener('mouseup', (event) => {
  isDragging = false;
  console.log('Mouse up', event.offsetX, event.offsetY);
});

canvas.addEventListener('mousemove', (event) => {

  const { x, y } = toScaledMousePos(event.clientX, event.clientY);

  mouseX = x;
  mouseY = y;

  if(isDragging) {
    drawLine(previousX, previousY, x, y, r, g, b); // Draw a line from previous position to current position with the current color
    //putPixel(x, y, r, g, b); // Draw a pixel at current position with the current color
    ctx.putImageData(imageData, 0, 0);
  }
  previousX = x;
  previousY = y;
});

window.addEventListener('keydown', (event) => {
  console.log('Key down:', event.key);
  if(event.key === '1') {
    r = 255; g = 0; b = 0; // Change to red แดง
  }
  else if(event.key === '2') {
    r = 0; g = 255; b = 0; // Change to green เขียว
  } 
  else if(event.key === '3') {
    r = 0; g = 0; b = 255; // Change to blue น้ำเงิน
  }


  if(event.key === 'ArrowLeft') {
    degree -= 5; // Rotate left
  }
  else if(event.key === 'ArrowRight') {
    degree += 5; // Rotate right
  }

  if(event.key === 'ArrowUp') {
    scale += 0.1; // Scale up
  }
  else if(event.key === 'ArrowDown') {
    scale -= 0.1; // Scale down
  }

});
window.addEventListener('keyup', (event) => {
  console.log('Key up:', event.key);
});

